<link rel="stylesheet" href="styles.css"><style ng-app-id="ng">

.center-content-container[_ngcontent-ng-c2283532919] {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  padding-top: 50px;
}
.welcome-card[_ngcontent-ng-c2283532919] {
  max-width: 400px;
  text-align: center;
}
.button-group[_ngcontent-ng-c2283532919]   button[_ngcontent-ng-c2283532919] {
  width: 120px;
}
/*# sourceMappingURL=/app.css.map */</style><style ng-app-id="ng">

.toolbar-spacer[_ngcontent-ng-c180352679] {
  flex: 1 1 auto;
  margin-right: 15px;
}
.separator-bar[_ngcontent-ng-c180352679] {
  margin: 0 10px;
  color: rgba(255, 255, 255, 0.5);
}
mat-toolbar[_ngcontent-ng-c180352679] {
  display: flex;
  align-items: center;
  padding: 0 16px;
  height: 64px;
}
mat-toolbar[_ngcontent-ng-c180352679]   img.toolbar-logo[_ngcontent-ng-c180352679] {
  height: 44px !important;
  width: auto;
  margin-right: 20px;
  border-radius: 8px;
  object-fit: contain;
  background: rgba(255, 255, 255, 0);
  padding: 4px;
}
.sad-icon[_ngcontent-ng-c180352679] {
  font-size: 80px;
  color: #ddd;
  margin-bottom: 16px;
}
.app-logo-only[_ngcontent-ng-c180352679] {
  height: 48px !important;
  margin-right: 12px;
}
.toolbar-logo.profile-image[_ngcontent-ng-c180352679] {
  height: 40px;
  width: 40px;
  border-radius: 50% !important;
  object-fit: cover;
  margin-right: 12px;
  border: 2px solid rgb(0, 0, 0);
}
