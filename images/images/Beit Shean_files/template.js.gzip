    var $button = $dropdown.find('.dropdown-toggle');
    var $menu = $dropdown.find('.dropdown-menu');

    $button.on('click', function (event) {
        event.preventDefault();
        var expanded = $(this).attr('aria-expanded') === 'true';
        $(this).attr('aria-expanded', !expanded);
        $menu.toggleClass('show');
    });

    $(document).on('click', function (event) {
        if (!$dropdown.is(event.target) && $dropdown.has(event.target).length === 0) {
            $button.attr('aria-expanded', 'false');
            $menu.removeClass('show');
        }
    });

    $('.mobile_menu li.menu-item-has-children').not('.menu-item-lang').click(function(){     
        var isLangOpen = $('.menu-item-lang').hasClass('open');   
        if(isLangOpen) {
            $('.mobile_menu .language-toggle').attr('aria-expanded', 'false');
        }
    });
    $('.mobile_menu li.menu-item-has-children').click(function() {
        $(this).toggleClass('open');
    });
    
    $('.top_menu .navbar-header .btn-menu').click(function() {
        $(this).closest('header').toggleClass('menu-responsive-open');
        var $mobileMenu = $('.mobile_menu');
        if ($mobileMenu.hasClass('open')) {
            $mobileMenu.removeClass('open');
            $mobileMenu.one('transitionend', function() {
                $('.mobile_menu li.menu-item-has-children').removeClass('open');
                $('.language-toggle').attr('aria-expanded', 'false'); 
            });
        } else {
            $mobileMenu.addClass('open');
        }
    });

    $('.mobile_menu .language-toggle').on('click', function(e) {
        e.preventDefault(); 
        var $submenu = $(this).siblings('.sub-menu'); 
        var expanded = $(this).attr('aria-expanded') === 'true';
        $submenu.toggleClass('open'); 
        $(this).attr('aria-expanded', !expanded); 
    });
  
    function accessibilityMenu() {
        if ($(window).width() < 992) {
            $('#mobile_menu').append('<li id="menu-item-accessibility" class="menu-item menu-item-type-custom menu-item-object-custom"></li>');
            $("#menu-item-accessibility").append($('#INDbtnWrap'));
        } 
    }
    accessibilityMenu();
    if ($(window).width() <= 991) { 
        $('.mobile_menu li.menu-item-has-children > a').click(function(e) {
            e.preventDefault(); 
        });       
    }
});
function toggleReadMore(elm){
    var tempText=$(elm).text();        
    $(elm).parent().toggleClass('is_show');        
    $(elm).closest('.new_row').toggleClass('is_open');
    $(elm).closest('.start_cubes').toggleClass('desc_is_show');
    $(elm).html($(elm).attr('data-text'));
    $(elm).attr('data-text',tempText);

    var hightFirstCube= $('.activity_details.is_open> .col:nth-child(1) .wrap_cube_style');
    var hightSecondCube= $('.activity_details.is_open> .col:nth-child(2) .wrap_cube_style');
    if(hightFirstCube.innerHeight()>hightSecondCube.innerHeight())
        hightSecondCube.css("height", hightFirstCube.innerHeight());
    else
        hightFirstCube.css("height", hightSecondCube.innerHeight());           
}
//Function for Emergency Cookie
function setCookie(info, evalue) {
    if(info=='emergency' || info=='multi_emergency'){
        const d = new Date();
        d.setTime(d.getTime() + (10 * 60 * 1000));
        let expires = "expires="+d.toGMTString();
        document.cookie = info + "=" + evalue + ";" + expires + ";path=/"; 
    }
    else if(info=='emergency_Session' || info=='multi_emergency_session'){
        document.cookie = info + "=" + evalue + ";" + 0 + "; path=/;";  
    }          
}
function hasCookie(name){
    let elements = $(".flashback-emergency").map(function() {
        return this.id;
    }).get();      
    let cookie = getCookie(name);              
    let find= elements.indexOf(cookie);
    if(getCookie(name) == ''|| find < 0) {                              
        let emergency_id ='';                                                   
        if($(".flashback-emergency").length >= 2 && (name=='multi_emergency' || name=='multi_emergency_session')){//for multiply emergency  
            emergency_id = $(".flashback-emergency:eq(0)").attr('id');                                              
        }                            
        else if(name=='emergency' || name=='emergency_Session'){ //for emergency Cookie
           if( $(".flashback-emergency").length >= 2){
             emergency_id = $(".flashback-emergency:eq(1)").attr('id');
           }
           else{
             emergency_id = $(".flashback-emergency").attr('id');
           }                                
        }                            

        if($(".flashback-emergency").attr('id')){
            $(".wrap-flashback-emergency" ).show();
        }  
        if(emergency_id != "" && emergency_id != null) {
            setCookie(name, emergency_id);
        }                       

    }  
}  
function getCookie(name) {
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if (parts.length === 2) return parts.pop().split(';').shift();
}

//play and pause for video banner
 var player;

  //this function gets called when API is ready to use
  function onYouTubeIframeAPIReady() {
    player = new YT.Player('video', { 
      events: {
        'onReady': onPlayerReady
      }
    });
  }

  function onPlayerReady(event) {
    //if has button Play and Pause 
    var playBtn = document.getElementById('play-button');
    var pauseBtn = document.getElementById('pause-button');

    if (playBtn) {
      playBtn.addEventListener('click', function() {
        player.playVideo();
      });
    }

    if (pauseBtn) {
      pauseBtn.addEventListener('click', function() {
        player.pauseVideo();
      });
    }

    //if has button Pause ו-Play
    var pausePlayBtn = document.getElementById('pause-play');
    if (pausePlayBtn) {
      var icon = pausePlayBtn.querySelector('i');
      pausePlayBtn.addEventListener('click', function() {
        if (!icon) return;
        if (icon.classList.contains('fa-pause')) {
          icon.classList.remove('fa-pause');
          icon.classList.add('fa-play');
          player.pauseVideo();
        } else {
          icon.classList.remove('fa-play');
          icon.classList.add('fa-pause');
          player.playVideo();
        }
      });
    }
  }


// Inject YouTube API script
var tag = document.createElement('script');
tag.src = "https://www.youtube.com/player_api";
var firstScriptTag = document.getElementsByTagName('script')[0];
firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

function init_fancybox(){
    if($(".gallery-fancybox").length > 0){
        $(".gallery-fancybox").fancybox({
            width: '800', // Set desired width
            height: '450', // Set desired height
            maxWidth: '800',
            maxHeight: '600',  
            prevEffect: 'none',
            nextEffect: 'none',
            loop: true, // Enables cycling through images
            buttons: ["zoom", "slideShow", "thumbs", "close"],
          
            beforeLoad: function(instance, current) {
                var $el = current.opts.$orig;
                var title = $el.attr('title') || 'No Title';
                var description = $el.attr('data-description') || '';
                var caption = $el.attr('caption');                
                $(".fancybox-container").addClass("fancybox-wrap-gallery fancybox-desktop fancybox-type-image fancybox-opened");             
                $(".gallery-fancybox-inner").remove();
                $(".fancybox-content").append(
                    '<div class="gallery-fancybox-inner clearfix"><div class="fancybox-right"><h4>' + title + '</h4> <p>' + description + '</p></div><span class="fancybox-left">' + caption + '</span></div>'
                );
                $(".fancybox-nav").remove();
                $(".fancybox-content").append(  
                    '<a title="Close" class="fancybox-item fancybox-close" href="javascript:;"></a>' +
                    '<div class="fancybox-nav">' +
                    '<a title="Previous" class="fancybox-nav fancybox-next" href="javascript:;"><span></span></a>' +
                    '<a title="Next" class="fancybox-nav fancybox-prev" href="javascript:;"><span></span></a>' +
                    "</div>"
                );

                $(".fancybox-prev").on("click", function () {
                    $('.fancybox-button.fancybox-button--arrow_left').click();
                });
                
                $(".fancybox-next").on("click", function () {
                    $('.fancybox-button.fancybox-button--arrow_right').click();
                });

                $(".fancybox-close").on("click", function () {
                    $('.fancybox-button.fancybox-button--close').click();
                });;
 
            },

            afterClose: function () {
                // ✅ Remove custom navigation buttons after closing
                $(".custom-title, .custom-nav,.fancybox-nav").remove();
                $(".fancybox-container").removeClass("fancybox-wrap-gallery fancybox-desktop fancybox-type-image fancybox-opened");
            }
        });
    }
}

function svg_home_map(isMobile = false){
    $('#all-map path').removeClass('active');
    //$('.area_map path[fill="#B5D838"]').not($(this)).addClass('active');
    el = $(this);
    slug = $(this).attr('data-slug');
    
    if(el.prop("nodeName") === "tspan" ){
        slug = $(this).parent().attr('data-slug');
    }
    if (typeof slug === 'undefined'){
        $('.buble_map').css('display','none');
        return;
    }
    if ((el.prop("nodeName").toLowerCase() === "tspan" )|| el.prop("nodeName").toLowerCase()=== 'text') {
        el2 = $('.area_map path[data-slug="'+slug+'"]');
    }else{
        el2 = $(this);
    }
    el2.addClass('active');
    if(isMobile){
        topel = $(el2).attr('data-m-top');
        leftel = $(el2).attr('data-m-left');
        //leftel = Number(leftel) * 0.5;
        if(leftel > 200){
            leftel = leftel-115;
            $('.buble_map').addClass('right');
        }else{
            $('.buble_map').removeClass('right');
        }
    }else{
        if($('#area-section').attr('active-area')!='-1'){
            topel = $(el2).attr('data-area-top');
            leftel = $(el2).attr('data-area-left');
        }else{
            topel = $(el2).attr('data-top');
            leftel = $(el2).attr('data-left');
        }
        
    }
    
    title = $('.area_trip[data-slug="'+slug+'"]').first().find('h4').text();
    text = $('.area_trip[data-slug="'+slug+'"]').first().find('p').text();
    link = $('.area_trip[data-slug="'+slug+'"]').first().attr('href');
    $('.buble_map h5').text(title);
    $('.buble_map #buble_map_text').text(text);
    $('.buble_map a').attr('href',link);
    $('.buble_map').css('display','block');    
     
    if (!isNaN(topel) && !isNaN(leftel)) {
        $('.buble_map').css({
            'top': topel + 'px',
            'left': leftel + 'px'
        });
    }
}

$(window).on("scroll", function () {
    if(($(window).width() < 992)){
        const $floatingElement = $(".shared.icons");
        const windowHeight = $(window).height();
        const documentHeight = $(document).height();
        const scrollTop = $(window).scrollTop();
        const stopDistance = 200; 

        const stopPoint = documentHeight - windowHeight - stopDistance;

        if (scrollTop >= stopPoint) {       
            $floatingElement.addClass("stopped");

        } else {     
            $floatingElement.removeClass("stopped");
        }
    }
});