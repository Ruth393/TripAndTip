$ =jQuery;
function crop(p, height) {
    while ($(p).outerHeight() > height) {
        $(p).text(function(index, text) {
            return text.replace(/\w*\s(\S)*$/, '…');
        });
    };
}

function iframeHeight(iframeHeight) {
    document.getElementById("iframe_tmpl_tenders").style.height = iframeHeight + "px";
    document.getElementById("iframe_tmpl_tenders").style.minHeight = iframeHeight + "px";
}

$(window).on("message", function(e) {
    if (e.originalEvent.data.msg == 'iframeHeight') {
        iframeHeight(e.originalEvent.data.height);
    }
});



function readCookie(name)
{
    var cookiename = name + "=";
    var ca = document.cookie.split(';');
    for(var i=0;i < ca.length;i++)
    {
    var c = ca[i];
    while (c.charAt(0)==' ') c = c.substring(1,c.length);
    if (c.indexOf(cookiename) == 0) return c.substring(cookiename.length,c.length);
    }
return null;
}

function getUrlParameter(name) {
    name = name.replace(/[\[]/, '\\[').replace(/[\]]/, '\\]');
    var regex = new RegExp('[\\?&]' + name + '=([^&#]*)');
    var results = regex.exec(location.search);
    return results === null ? '' : decodeURIComponent(results[1].replace(/\+/g, ' '));
};

function getQueryParams(url) {
    const queryString = url.split('?')[1];
    if (!queryString) {
        return {};
    }
    const pairs = queryString.split('&');
    const params = {};
    pairs.forEach(function(pair) {
        const [key, value] = pair.split('=');
        params[decodeURIComponent(key)] = decodeURIComponent(value || '');
    });
    return params;
}

jQuery(document).ready(function($) {
      function initExitPopup(options) {
        var settings = $.extend({
            popupSelector: "#exitPopup",
            popupId: "defaultPopup",
            inactivitySeconds: 25,
            maxShows: 3,
            minInterval: 24 * 60 * 60 * 1000,  
            scrollPercent: 80
        }, options);

        var storageKey = "exitPopupData_" + settings.popupId;
        var data = JSON.parse(localStorage.getItem(storageKey)) || { count: 0, lastShown: null };
        var inactivityTimer;

        function showPopup() {
            var now = Date.now();
            if (data.count >= settings.maxShows) return;
            if (data.lastShown && now - data.lastShown < settings.minInterval) return;
            if (!$(settings.popupSelector).length) return;

            $(settings.popupSelector).fadeIn();
            $('body').addClass('popup-open');

            data.count++;
            data.lastShown = now;
            localStorage.setItem(storageKey, JSON.stringify(data));
        }

        function resetTimer() {
            clearTimeout(inactivityTimer);
            inactivityTimer = setTimeout(showPopup, settings.inactivitySeconds * 1000);
        }

        //inactivity
        $(document).on("mousemove click scroll", resetTimer);
        resetTimer();

        // Desktop exit intent
        $(document).off("mouseleave.exitIntent").on("mouseleave.exitIntent", function(e) {
            if (e.clientY <= 0) showPopup();
        });

        // Mobile scroll trigger only
        if (window.innerWidth < 768) {
            $(window).on("scroll", function() {
                var scrollTop = $(window).scrollTop();
                var docHeight = $(document).height() - $(window).height();
                var scrollPercent = (scrollTop / docHeight) * 100;
                if (scrollPercent >= settings.scrollPercent) showPopup();
            });
        }

        // Close popup
        $(document).on("click", settings.popupSelector + " #closePopup", function() {
            $(settings.popupSelector).fadeOut();
            $('body').removeClass('popup-open');
        });
    }

    // Initialize
    initExitPopup({
        popupSelector: "#exitPopup",
        popupId: $("#exitPopup").data("popup-id"),
        inactivitySeconds: 25,
        minInterval: 24 * 60 * 60 * 1000,
        scrollPercent: 80,
        maxShows: 3
    });
    
