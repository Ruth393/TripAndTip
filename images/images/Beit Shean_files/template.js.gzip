    });

    $(".result-search-page .tabs").change(function() {    
        var id = $(this).find(':selected').attr('id');
        var uri = window.location.toString();

        if (id != '-3' && id != '-4' && id != '-5') {
            
            if (uri.indexOf('page') == -1)
                uri = sessionStorage.getItem("uri");
            if (uri !== null) {  
                var re = new RegExp("([?&])" + 'cat' + "=.*?(&|$)", "i");
                if (uri.indexOf('all') == -1)
                    uri += '&all=1';
                newurl = uri.replace(re, '$1' + 'cat' + "=" + id + '$2');
                if (id == '575')
                    newurl = uri.replace(re, '$1' + 'cat' + "=" + ['575', '626']);
                window.location.replace(newurl);
            }
            $('.tabs .tab.active').removeClass('active');
            $(this).find(':selected').addClass('active');
        } else {
            if (uri.indexOf('page') != -1)
                sessionStorage.setItem('uri', uri);
            var uri = window.location.toString();
            p = (uri.indexOf('post_type')) - 1;
            if (p)
                newuri = uri.substr(0, uri.indexOf('cat=') + 4);
            if (id == '-3')
                newuri = newuri + id + '&post_type=attachment&all=1&post_mime_type%5B0%5D=application&post_mime_type%5B1%5D=text';
            else if (id == '-4')
                newuri = newuri + id + '&post_type=attachment&all=1&post_mime_type=image';
            else newuri = newuri + id + '&post_type=attachment&all=1&post_mime_type=video';
            window.location.replace(newuri);
            $('.tabs .tab.active').removeClass('active');
            $(this).find(':selected').addClass('active');

        }
    });

