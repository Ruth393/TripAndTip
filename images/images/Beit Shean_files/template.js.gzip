            var newPage = page + 1;
            var ajaxurl = $('#loadMore').data('url');
            var favorite = [];
            //check
            if ($(window).scrollTop() >= ($(document).height() - $(window).height() - $('footer').height())) {
                if (!$('#loadMore').hasClass('active')) {
                    $('#loadMore').append('<span id="loader"></span>');
                    $('#loadMore').addClass('active');
                    
                    if($('.filter_tag')){
                    // $.each($(".filter_tag .btn"), function(){
                        favoriteArr = [];
                        if(!$('#all').hasClass('active')){
                            $.each($('.btn.green.active'), function(){
                                var temp = $(this).attr('id');
                                favoriteArr.push([temp]);
                            });
                        }
                        if($('#all').hasClass('active')){
                            favorite=[];
                        }
                        if(favoriteArr.length != 0){
                            favorite = favoriteArr;
                        }
                    }

                    if ($(".filterLine input")) {

                        $.each($(".filterLine"), function(){
                            favoriteArr = [];
                            $(this).find('input[type=checkbox]:checked').each(function(){
                                if($(this).hasClass('area')){
                                    var area = $(this).attr('data-area');
                                    if($("input[data-parentarea='"+area+"']:checked").length == 0){
                                        var temp = $(this).attr('id');
                                        favoriteArr.push($("label[for='" +  temp + "']").text());
                                    }
                                }
                                else{
                                    var temp = $(this).attr('id');
                                    favoriteArr.push($("label[for='" +  temp + "']").text());
                                }

                            });
                            if(favoriteArr.length != 0){
                                favorite.push(favoriteArr);
                            }
                        });

                    }
                    //ajax call
                    $.ajax({
                        url: '/ajax-handler-wp-loadmore.php',
                        type: 'get',
                        data: {
                            page: page,
                            args: args,
                            st: 9,
                            action: 'ajax_script_load_more',
                            tag: favorite
                        },
                        error: function(response) {
                            console.log(response);
                        },
                        success: function(response) {
                            if (response == 0) {
                                $('#loadMore').html('');
                            } else {
                                //check
                                $('#loadMore').html('');
                                $('#loadMore').removeClass('active');
                                // if (count_all_pages == newPage) {
                                //     $('#loadMore').remove();
                                // }
                                $('#loadMore').data('page', newPage);
                                $('#sea-content').append(response);
                                $('.opacity_load').animate({ opacity: 1 }, 1000);
                            }

                        }
                    });
                }
            }
        }
    });

