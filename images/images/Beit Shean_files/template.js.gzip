    $(window).on("load", function() {

        // Example URL
        const url = window.location.href;
            
        // Split the URL to isolate the fragment and query parts
        const [baseAndFragment, queryString] = url.split('?');
        const [baseUrl, fragment] = baseAndFragment.split('#');
        
        // Extract query parameters using the helper function
        const params = getQueryParams(url);

        var myArray = {'utm_source': params.utm_source, 'utm_medium': params.utm_medium, 'utm_campaign': params.utm_campaign,'utm_term': params.utm_term};
        for (var key in myArray) {
            if(myArray[key]!=''){
                $("body").attr(key,myArray[key]);
            }
        }
       
        $(".menu-item-link").each(function() {
            if ($(this).attr("href") == "#") {
                $(this).replaceWith('<div class="' + $(this).attr('class') + '">' + $(this).html() + "</div>");
            }
        });
    });

