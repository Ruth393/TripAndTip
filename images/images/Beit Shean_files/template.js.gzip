    function sliderHeight(ele){
        var heightBase = $(ele).data('id');;
        if (!(heightBase >= -9 && heightBase <= 9)) {
            heightBase = -5;
        }
        height = (heightBase * -1) + 9;

        var height_btn = $(ele).height();
        var height_slider = $('.wrapper_topSlider').height();
        height_slider = height_slider - height_btn;
        height_btn = height_btn/2;
        var part_position = height_slider/18;
        var position = (height * part_position);
        $(ele).show();
        $(ele).css('top', (position+height_btn) + 'px');
    }
    $(window).on("load", function() {
        if($('.btn.green.position').length > 1){
            $('.btn.green.position').each(function( index ) {
                sliderHeight($(this));
            });
        }
        else{
            sliderHeight($('.btn.green.position'));
        }
    });
    $(window).resize(function() {
        if($('.btn.green.position').length > 1){
            $('.btn.green.position').each(function( index ) {
                sliderHeight($(this));
            });
        }
        else{
            sliderHeight($('.btn.green.position'));
        }
    });

