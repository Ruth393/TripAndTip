    $(window).on("load", function() {          
        if(($(window).width() > 767)){
            $.fn.loopScroll = function(p_options) {
                var options = $.extend({
                    direction: "upwards",
                    speed: 60
                }, p_options);
    
                return this.each(function() {
                    var obj = $(this).find(".news");
                    var text_height = obj.find(".flashbacks-text").width() || 0; 
                    var news = text_height * 2;                
                    var w = $('#flashbacks-scroll').width() || 0;
                    var left = -Math.abs(news - w);
    
                    var start_y = left;
                    var end_y = 0;
    
                    var animate = function() {
                        obj.stop().animate(
                            { left: end_y },
                            1000 * Math.abs(end_y - parseInt(obj.css("left"))) / options.speed,
                            "linear",
                            function() {
                                obj.css("left", start_y);
                                animate();
                            }
                        );
                    };
    
                    obj.find(".flashbacks-text").clone().appendTo(obj);
    
                    // Ensure the click event is bound only once
                    $('.stop-scroll').off("click").on("click", function() {
                        if ($(this).hasClass("pause")) {
                            $(this).addClass("play").removeClass("pause");
                            obj.stop(); // Stop animation
                        } else {
                            $(this).removeClass("play").addClass("pause");
                            animate(); // Resume animation
                        }
                    });
    
                    $(document).on("mouseenter", "#flashbacks-scroll", function() {
                        $(this).addClass("play").removeClass("pause");
                        $('.stop-scroll').addClass("play").removeClass("pause");
                        obj.stop();  // Stop the animation
                    });
    
                    $(document).on("mouseleave", "#flashbacks-scroll", function() {
                        $(this).removeClass("play").addClass("pause");
                        $('.stop-scroll').removeClass("play").addClass("pause");
                        animate();  // Resume animation
                    });
    
                    obj.css("left", start_y);
                    animate(); // Start animation
                });
            };
    
            $(".rl #flashbacks-scroll").loopScroll({ direction: "downwards", speed: 30 });
        }

        /*area map*/
        if($(window).width() > 768){
            $('.area_map').on('mouseleave', '[data-slug],text,.buble_map', function(event) {
            //$('.area_map path[data-slug],.buble_map').mouseleave(function(){
                if($(".buble_map:hover,svg tspan:hover,svg text:hover").length == 0){
                    $('#all-map path').removeClass('active'); 
                    //$('.area_map path[fill="#B5D838"]').attr('fill','#E1F1A6')
                    $('.buble_map').css('display','none');
                } 
            } );
            
            $('#area-section').on('mouseleave', '.area_trips_card', function(event) {
                $('.area_map [data-slug]').removeClass('active');
                $('.area_trips_card').css('background','#fff');
            });

            $('#area-section').on('mouseleave', '.buble_map', function(event) {
