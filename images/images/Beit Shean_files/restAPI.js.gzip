                          //  $('#activity-home .locatins_tab button').eq(i).click();
                        //}
                    }
                } catch (error) {
                    console.error("Failed to parse JSON:", error);
                    return;
                }
            }
        });
    }

    function recommendationsSwiper(
        container, 
        slidesPerView, 
        slidesPerViewLeptop = slidesPerView, 
        slidesPerViewMobile = slidesPerView, 
        parentContainer = container, 
        loop = false, 
        spaceBetween = 15, 
        autoplay = false,
        speed = 300,
        spaceBetweenMobile = spaceBetween

    ) {
        var next = parentContainer + ' .swiper-button-next';
        var prev = parentContainer + ' .swiper-button-prev';  
        var pagination = parentContainer + ' .swiper-pagination';
    
        if(autoplay){
            const $toggleBtn = $('<button class="button" id="swiper-toggle" aria-label="pause play"><i class="fa fa-pause" aria-hidden="true"></i></button>');
            $(parentContainer + ' .pagination').append($toggleBtn);
        }

        // Append the toggle button to the container
        
        const swiperOptions = {
            loop: loop,                       
            direction: 'horizontal',
            slidesPerView: slidesPerViewMobile,
            spaceBetween: spaceBetweenMobile,
            navigation: {
                nextEl: next,
                prevEl: prev,
            },
            pagination: {
                el: pagination,
                clickable: true,
            },
            breakpoints: {
                768: {
                    spaceBetween: spaceBetweenMobile,
                    slidesPerView: slidesPerViewLeptop,
                },
                1199: {
                    spaceBetween: spaceBetween,
                    slidesPerView: slidesPerView,
                },
            },
            speed: speed,
        };
    
        if (autoplay) {
            swiperOptions.autoplay = {
                delay: 3000,
                disableOnInteraction: false,
            };
        }
    
        // Create and return the Swiper instance
        const swiperInstance = new Swiper(container + '.swiper-container', swiperOptions);
    
        // Set up play/pause toggle
        let isPlaying = true;

        $(document).on("click", "#swiper-toggle", function () {
            if (isPlaying) {
                swiperInstance.autoplay.stop();
                $(this).text('Play');
                $(this).html('<i class="fa fa-play" aria-hidden="true"></i>');
            } else {
                swiperInstance.autoplay.start();
                $(this).text('Pause');
                $(this).html('<i class="fa fa-pause" aria-hidden="true"></i>');
            }
            isPlaying = !isPlaying;
        });
    
        return swiperInstance;
    }

    function loadAcitivty($url){
        $url = "/wp-content/uploads/jsonfiles/" + $url;
        console.log($url);
        $.ajax({
            type: "GET",  
            url : $url,
            success: function(jsonResponse) {
                var obj;
                try {
                    obj = JSON.parse(jsonResponse);
                } catch (error) {
                    console.error("Failed to parse JSON:", error);
                    return; // Exit if parsing failed
                }
                var j=0;
                var i = 0;
                
                $('.activity_container').fadeOut(300, function() {
                    $(this).html(""); // Clear content AFTER fade out
                
                    // Append new content
                    $(this).append('<div id="activity-swiper" class="swiper-container" dir="rtl"><div class="activity-box swiper-wrapper primary_color" dir="rtl"></div></div><div class="swiper-button-prev"></div><div class="swiper-button-next"></div>');
                
                    $.each(obj, function(key, value) {
                        var sub_title = value.sub_title ? `<span class="details fs-20 m-font-14 d-block">${value.sub_title}</span>` : '';
                
                        $('.activity-box').append(`
                            <div id="activity${i}" dir="rtl" data-id="${value.id}" class="card swiper-slide primary_color">
                                <a name="activity${i}" href="${value.activity_link}" aria-label="${decodeURIComponent(value.activity_title)}">
                                    <div class="relative">
                                        <img loading="lazy" class="card-img-big br-10 object-fit-cover" src="${value.image_url}" 
                                            alt="${value.image_alt}" title="${value.image_title}">
                                        <h3 class="label second_green_background br-10 absolute fs-16 m-font-14">${value.area}</h3>
                                    </div>
                                    <h4 class="h3-new fw-700 m-font-16">${decodeURIComponent(value.name)}</h4>
                                    ${sub_title}
                                </a>
                                <div class="dates fs-16 m-font-14 d-block">${value.dates}</div>
                                <div class="icons_texts_wrap"></div>
                            </div>
                        `);
                
                        let activityEl = $(`#activity${i} .icons_texts_wrap`);
                
                        if (value.location_name) {
                            if (value.lcation_link) {
                                activityEl.append(`<a name="location_activity" href="${value.lcation_link}" class="icon_text">
                                    <img src="${value.lcation_icon}" alt="${value.location_name}">
                                    <span class="fs-18 m-font-14">${value.location_name}</span>
                                </a>`);
                            } else {
                                activityEl.append(`<div class="icon_text">
                                    <img src="${value.lcation_icon}" alt="${value.location_name}">
                                    <span class="fs-18 m-font-14">${value.location_name}</span>
                                </div>`);
                            }
                        }
                        if (value.price_text) {
                            activityEl.append(`<div class="icon_text">
                                <img src="${value.price_icon}" alt="${value.price_text}">
                                <span class="fs-18 m-font-14">${value.price_text}</span>
                            </div>`);
                        }
                        if (value.tag_text) {
                            activityEl.append(`<div class="icon_text">
                                <img src="${value.tag_icon}" alt="${value.tag_text}">
                                <span class="fs-18 m-font-14">${value.tag_text}</span>
                            </div>`);
                        }
                
                        i++;
                    });
                    console.log(i);
                    loop =  i < 5 ? false : true;
                    console.log(loop);
                    if (w > 768) {
                        recommendationsSwiper('#activity-swiper',4,3,'auto','#activity-home',loop,30);
                    } else {
                        recommendationsSwiper('#activity-swiper', 4, 3, 1.74, '#activity-home', false, 20);
                    }
                
                    $(this).fadeIn(300); // Fade in AFTER content is added
                });
                if((i < 4 && w <= 1024) || (i < 5 && w > 1024) ||  w < 768){
                    $('#activity-home .swiper-button-next').hide();
                    $('#activity-home .swiper-button-prev').hide();
                }
                $('#activity-home').addClass('in');                
            }
        });
    }

    $('#activity-home .locatins_tab button').click(function(){
        if ($(this).hasClass("active")) {  
            return;  
        }
        $('#activity-home .locatins_tab button').removeClass('active');
        $(this).addClass('active');
        var id = $(this).attr('data-id');
        $('.activity-box').empty();
        loadAcitivty("he_activityArea"+id+".json");
        
    });

